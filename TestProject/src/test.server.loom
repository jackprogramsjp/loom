interface Item {
    name: string;
    price: number;
    quantity: number;
}

fn total(items: Item[]): number {
    mut sum = 0;
    for item : items
        sum += item.price * item.quantity;

    return sum;
}

let items = [
    new Item { name: "Keyboard", price: 80, quantity: 2 },
    new Item { name: "Mouse", price: 25, quantity: 4 },
    new Item { name: "Monitor", price: 300, quantity: 1 }
];

print(total(items));