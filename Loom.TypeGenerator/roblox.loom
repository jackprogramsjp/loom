}

declare interface CFrame {
    [luau_name("X")] x: number;
    [luau_name("Y")] y: number;
    [luau_name("Z")] z: number;
    [luau_name("Position")] position: Vector3;
    [luau_name("Rotation")] rotation: CFrame;
    [luau_name("LookVector")] look_vector: Vector3;
    [luau_name("RightVector")] right_vector: Vector3;
    [luau_name("UpVector")] up_vector: Vector3;
    [luau_name("XVector")] x_vector: Vector3;
    [luau_name("YVector")] y_vector: Vector3;
    [luau_name("ZVector")] z_vector: Vector3;
}

declare interface CFrameStatic {
    identity: CFrame;
    [luau_name("Angles")] angles: fn(x: number, y: number, z: number): CFrame;
    [luau_name("lookAt")] look_at: fn(at: Vector3, lookAt: Vector3, up: Vector3?): CFrame;
    [luau_name("lookAlong")] look_along: fn(at: Vector3, direction: Vector3, up: Vector3?): CFrame;
    [luau_name("fromEulerAngles")] from_euler_angles: fn(x: number, y: number, z: number, order: Enum["RotationOrder"]?): CFrame;
    [luau_name("fromEulerAnglesXYZ")] from_euler_angles_xyz: fn(x: number, y: number, z: number): CFrame;
    [luau_name("fromEulerAnglesYXZ")] from_euler_angles_yxz: fn(x: number, y: number, z: number): CFrame;
    [luau_name("fromOrientation")] from_orientation: fn(x: number, y: number, z: number): CFrame;
    [luau_name("fromAxisAngle")] from_axis_angle: fn(vector: Vector3, rotation: number): CFrame;
    [luau_name("fromMatrix")] from_matrix: fn(pos: Vector3, vX: Vector3, vY: Vector3, vZ: Vector3): CFrame;
}

