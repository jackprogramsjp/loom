    Distance: number;
    ## Instance: Instance?;
    Material: Enum["Material"];
    Position: Vector3;
    Normal: Vector3;
}

declare interface RaycastParams {
    ## mut FilterDescendantsInstances: Instance[]?;
    mut FilterType: Enum["RaycastFilterType"];
    mut IgnoreWater: bool?;
    mut CollisionGroup: string;
    mut RespectCanCollide: bool?;
    mut BruteForceAllSlow: bool?;
}

declare interface OverlapParams {
    ## mut FilterDescendantsInstances: Instance[]?;
    mut FilterType: Enum["RaycastFilterType"];
    mut MaxParts: number;
    mut CollisionGroup: string;
    mut RespectCanCollide: bool?;
    mut BruteForceAllSlow: bool?;
}

declare interface UDim {
    Scale: number;
    Offset: number;
}

