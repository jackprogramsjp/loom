## Handwritten Roblox types

declare interface buffer;
declare interface thread;

interface UnknownRecord {
    [unknown]: unknown;
}

## Property attribute - marks that a method will be called with the ':' operator
declare fn luau_method: void;

## Property attribute - allows overriding interface members
declare fn override: void;

declare fn print(msg: unknown): void;

declare interface ScriptSignal;

declare interface ScriptConnection {
    Connected: bool;
    [luau_method] Disconnect: fn: void;
}

declare interface SecurityCapabilities;

declare interface DateTime {
    UnixTimestamp: number;
    UnixTimestampMillis: number;
    
    [luau_method] ToUniversalTime: fn: TimeTable;
    [luau_method] ToLocalTime: fn: TimeTable;
    [luau_method] ToIsoDate: fn: string;
    [luau_method] FormatUniversalTime: fn(format: string, locale: string): string;
    [luau_method] FormatLocalTime: fn(format: string, locale: string): string;
}

declare interface DateTimeStatic {
    now: fn: DateTime;
    fromIsoDate: fn(isoDate: string): DateTime?;
    fromLocalTime: fn(year: number?, month: number?, day: number?, hour: number?, minute: number?, second: number?, millisecond: number?): DateTime;
    fromUniversalTime: fn(year: number?, month: number?, day: number?, hour: number?, minute: number?, second: number?, millisecond: number?): DateTime;
    fromUnixTimestamp: fn(unixTimestamp: number): DateTime;
    fromUnixTimestampMillis: fn(unixTimestampMillis: number): DateTime;
}

declare let DateTime: DateTimeStatic;

declare interface Content {
    SourceType: Enum["ContentSourceType"];
    Uri: string?;
    ## Object: Object?;
}

declare interface ContentStatic {
    ## none: Content;
    fromUri: fn(uri: string): Content;
    ## fromObject: fn(object: Object): Content;
}

declare let Content: ContentStatic;

declare interface Vector2 {
    X: number;
    Y: number;
    Magnitude: number;
    Unit: Vector2;
    
    [luau_method] Abs: fn: Vector2;
    [luau_method] Ceil: fn: Vector2;
    [luau_method] Floor: fn: Vector2;
    [luau_method] Sign: fn: Vector2;
    [luau_method] Cross: fn(other: Vector2): Vector2;
    [luau_method] Angle: fn(other: Vector2, isSigned: bool): number;
    [luau_method] Dot: fn(other: Vector2): number;
    [luau_method] FuzzyEq: fn(other: Vector2, epsilon: number?): bool;
    [luau_method] Lerp: fn(goal: Vector2, alpha: number): Vector2;
    [luau_method] Max: fn(other: Vector2): Vector2;
    [luau_method] Min: fn(other: Vector2): Vector2;
}

declare interface Vector2Static {
    zero: Vector2;
    one: Vector2;
    yAxis: Vector2;
    xAxis: Vector2;
    zAxis: Vector2;
}

declare let Vector2: Vector2Static;

declare interface Vector2int16 {
    X: number;
    Y: number;
}

declare interface Vector3 {
    X: number;
    Y: number;
    Z: number;
    Magnitude: number;
    Unit: Vector3;
    
    [luau_method] Abs: fn: Vector3;
    [luau_method] Ceil: fn: Vector3;
    [luau_method] Floor: fn: Vector3;
    [luau_method] Sign: fn: Vector3;
    [luau_method] Cross: fn(other: Vector3): Vector3;
    [luau_method] Angle: fn(other: Vector3, isSigned: bool): number;
    [luau_method] Dot: fn(other: Vector3): number;
    [luau_method] FuzzyEq: fn(other: Vector3, epsilon: number?): bool;
    [luau_method] Lerp: fn(goal: Vector3, alpha: number): Vector3;
    [luau_method] Max: fn(other: Vector3): Vector3;
    [luau_method] Min: fn(other: Vector3): Vector3;
}

declare interface Vector3Static {
    zero: Vector3;
    one: Vector3;
    yAxis: Vector3;
    xAxis: Vector3;
    zAxis: Vector3;
    FromNormalId: fn(normal: Enum["NormalId"]): Vector3;
    FromAxis: fn(axis: Enum["Axis"]): Vector3;
}

declare let Vector3: Vector3Static;

declare interface Vector3int16 {
    X: number;
    Y: number;
    Z: number;
}

declare interface CFrame {
    X: number;
    Y: number;
    Z: number;
    Position: Vector3;
    Rotation: CFrame;
    LookVector: Vector3;
    RightVector: Vector3;
    UpVector: Vector3;
    XVector: Vector3;
    YVector: Vector3;
    ZVector: Vector3;
}

declare interface CFrameStatic {
    identity: CFrame;
    Angles: fn(x: number, y: number, z: number): CFrame;
    lookAt: fn(at: Vector3, lookAt: Vector3, up: Vector3?): CFrame;
    lookAlong: fn(at: Vector3, direction: Vector3, up: Vector3?): CFrame;
    fromEulerAngles: fn(x: number, y: number, z: number, order: Enum["RotationOrder"]?): CFrame;
    fromEulerAnglesXYZ: fn(x: number, y: number, z: number): CFrame;
    fromEulerAnglesYXZ: fn(x: number, y: number, z: number): CFrame;
    fromOrientation: fn(x: number, y: number, z: number): CFrame;
    fromAxisAngle: fn(vector: Vector3, rotation: number): CFrame;
    fromMatrix: fn(pos: Vector3, vX: Vector3, vY: Vector3, vZ: Vector3): CFrame;
}

declare let CFrame: CFrameStatic;

declare interface Region3int16 {
    Min: Vector3int16;
    Max: Vector3int16;
}

declare interface Region3 {
    CFrame: CFrame;
    Size: Vector3;
}

declare interface Color3 {
    R: number;
    G: number;
    B: number;
}

declare interface Color3Static {
    fromRGB: fn(r: number?, g: number?, b: number?): Color3;
    fromHSV: fn(h: number?, s: number?, v: number?): Color3;
    fromHex: fn(hex: string): Color3;
}

declare let Color3: Color3Static;

declare interface BrickColor {
    Number: number;
    Name: string;
    Color: Color3;
    r: number;
    g: number;
    b: number;
}

declare interface BrickColorStatic {
    random: fn: BrickColor;
    palette: fn(paletteValue: number): BrickColor;
    White: fn: BrickColor;
    Gray: fn: BrickColor;
    DarkGray: fn: BrickColor;
    Black: fn: BrickColor;
    Red: fn: BrickColor;
    Yellow: fn: BrickColor;
    Green: fn: BrickColor;
    Blue: fn: BrickColor;
}

declare let BrickColor: BrickColorStatic;

declare interface Ray {
    Unit: Ray;
    Origin: Vector3;
    Direction: Vector3;
}

