fn empty {}
fn greet(name: string = "world") { return "Hello " + name }
fn sum(a: number, b: number): number { return a + b }
fn double(x: number) -> x * 2
fn wrap<T>(value: T): T { return value }
fn abc -> none
fn noArgs(): void {}
fn multiParam(a: number, b: string, c: bool): void {}
fn nestedGenerics<T, U: List<T>>(x: T, y: U): T { return x }
fn expressionBody(x: number, y: number) -> x + y