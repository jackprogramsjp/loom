interface EventObject {
    [luau_name("ConsumerEvent")]
    event consumer(param: string);
}

fn on_consumer(p: string): void {
    print("param: " + p)
}

let eo = none as never as EventObject;
eo.consumer += on_consumer;
eo.consumer("abc");
eo.consumer -= on_consumer;

[luau_name("NotUsed")]
event my_event(param: string);
