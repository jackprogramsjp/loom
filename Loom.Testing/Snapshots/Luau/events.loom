event my_event(param: number);

fn on_event(p: number): void {
    print("param: " + string(p))
}

trait Execute {
    fn execute(p: number): void;
}

interface Foo;

implement Execute for Foo {
    fn execute(p) -> print(p);
}

let foo = new Foo {};
my_event += foo.execute;
my_event += (mut []).push;
let conn = my_event += on_event;
conn.disconnect();