declare interface Foo {
    [luau_method]
    do_foo: fn: void;
}

declare interface Bar: Foo {
    foo: Foo;
}

declare interface Baz {
    [luau_method]
    do_baz: fn(p: number): void;
}

let bar = none as never as Bar;
bar.do_foo()
bar.foo.do_foo();

let baz = none as never as Baz;
baz.do_baz(69);