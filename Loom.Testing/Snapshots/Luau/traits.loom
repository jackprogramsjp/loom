trait ToString {
    fn to_string: string;
}

interface Person {
    name: string;
    age: number;
}

implement ToString for Person {
    fn to_string -> nameof(Person) + " { name: ''" + name + "', age: " + string(age) + " }"
}

let person = new Person { name: "Runic", age: 21 };
print(person.to_string());